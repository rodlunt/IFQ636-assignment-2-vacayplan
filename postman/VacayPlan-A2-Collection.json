            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"planning\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}"]
            }
          }
        },
        {
          "name": "State: active -> completed VALID (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}"]
            }
          }
        },
        {
          "name": "State: completed -> planning INVALID backward (400)",
          "description": "Trip is now completed. Going backward to planning is not allowed.",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"planning\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}"]
            }
          }
        },
        {
          "name": "Delete Trip - cascade via Facade (204)",
          "description": "Deletes trip and all its activities via tripService.deleteTripWithActivities (Facade pattern).",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Activities + Weather (Joe #91)",
      "description": "Activity CRUD and weather endpoint. Create a fresh trip first (re-run Create Trip from the Trips folder) to get a valid {{tripId}} in planning or active state before running these.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Auto-create a trip if tripId is not set (e.g. after Trips folder deletes it)",
              "if (!pm.environment.get('tripId')) {",
              "    pm.sendRequest({",
              "        url: pm.environment.get('base_url') + '/api/trips',",
              "        method: 'POST',",
              "        header: [",
              "            { key: 'Content-Type', value: 'application/json' },",
              "            { key: 'Authorization', value: 'Bearer ' + pm.environment.get('token') }",
              "        ],",
              "        body: {",
              "            mode: 'raw',",
              "            raw: JSON.stringify({",
              "                name: 'Activities Test Trip',",
              "                destination: 'Brisbane, Australia',",
              "                startDate: '2027-01-01',",
              "                endDate: '2027-01-07'",
              "            })",
              "        }",
              "    }, function(err, res) {",
              "        if (!err && res.code === 201) {",
              "            pm.environment.set('tripId', res.json()._id);",
              "            console.log('Pre-request: auto-created trip', res.json()._id);",
              "        }",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "item": [
        {
          "name": "Create Activity (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json._id) pm.environment.set('activityId', json._id);",
                  "    pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-09-05\",\n  \"time\": \"10:00\",\n  \"location\": \"Shibuya Crossing, Tokyo\",\n  \"description\": \"Morning visit to Shibuya\",\n  \"status\": \"wishlist\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}/activities",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}", "activities"]
            }
          }
        },
        {
          "name": "List Activities (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}/activities",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}", "activities"]
            }
          }
        },
        {
          "name": "Update Activity (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description via Postman\",\n  \"time\": \"11:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}/activities/{{activityId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}", "activities", "{{activityId}}"]
            }
          }
        },
        {
          "name": "Update Activity Status - booked (200)",
          "request": {
            "method": "PATCH",
