        {
          "name": "Wrong owner accessing activity (404)",
          "description": "Proves the ownershipDecorator returns 404 when a trip belongs to ANOTHER user (not merely when it does not exist). The pre-request registers a second user, creates a trip they own, and stores it in {{tripId2}}; the request below then accesses that trip's activities with the first user's {{token}} and must be rejected with 404.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Create a second user with their own trip so we can prove the Decorator",
                  "// rejects a non-owner with 404. Only do this once per environment.",
                  "if (!pm.environment.get('tripId2')) {",
                  "    const email = 'other-owner-' + Date.now() + '@delete.me';",
                  "    pm.sendRequest({",
                  "        url: pm.environment.get('base_url') + '/api/auth/register',",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json' },",
                  "        body: { mode: 'raw', raw: JSON.stringify({ name: 'Other Owner', email: email, password: 'Test1234!' }) }",
                  "    }, function (err, res) {",
                  "        if (!err && res.code === 201) {",
                  "            const otherToken = res.json().token;",
                  "            pm.sendRequest({",
                  "                url: pm.environment.get('base_url') + '/api/trips',",
                  "                method: 'POST',",
                  "                header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + otherToken },",
                  "                body: { mode: 'raw', raw: JSON.stringify({ title: 'Other Owner Trip', destination: 'Sydney, Australia', startDate: '2026-06-24', endDate: '2026-06-30' }) }",
                  "            }, function (e2, r2) {",
                  "                if (!e2 && r2.code === 201) {",
                  "                    pm.environment.set('tripId2', r2.json()._id);",
                  "                    console.log('Pre-request: created other-owner trip', r2.json()._id);",
                  "                }",
                  "            });",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 (non-owner rejected by Decorator)', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId2}}/activities",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId2}}", "activities"]
            }
          }
