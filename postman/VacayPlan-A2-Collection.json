        {
          "name": "Get Trip Weather - happy path (200)",
          "description": "Adapter pattern — Open-Meteo geocoding + forecast. The trip's near-term Brisbane dates fall inside Open-Meteo's forecast window, so a daily forecast is returned.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Resolved location returned', () => pm.expect(json.location).to.be.a('string'));",
                  "pm.test('Daily forecast returned', () => pm.expect(json.daily).to.be.an('array').that.is.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}/weather",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}", "weather"]
            }
          }
        },
        {
          "name": "Get Trip Weather - beyond forecast window (200 empty)",
          "description": "Adapter pattern edge case. The pre-request creates a trip dated a year out (stored in {{tripIdFar}}); Open-Meteo has no forecast that far ahead, so the adapter returns an empty daily array (HTTP 200), or a 502 if the vendor rejects the date range outright. Either is the expected 'no forecast available' outcome.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Create a far-future trip (beyond Open-Meteo's forecast window) once.",
                  "if (!pm.environment.get('tripIdFar')) {",
                  "    pm.sendRequest({",
                  "        url: pm.environment.get('base_url') + '/api/trips',",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + pm.environment.get('token') },",
                  "        body: { mode: 'raw', raw: JSON.stringify({ title: 'Beyond Window Trip', destination: 'Brisbane, Australia', startDate: '2027-06-24', endDate: '2027-06-30' }) }",
                  "    }, function (err, res) {",
                  "        if (!err && res.code === 201) {",
                  "            pm.environment.set('tripIdFar', res.json()._id);",
                  "            console.log('Pre-request: created beyond-window trip', res.json()._id);",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (empty) or 502 (vendor rejects range)', () => pm.expect([200, 502]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) {",
                  "    pm.test('No forecast for out-of-window dates', () => pm.expect(pm.response.json().daily).to.eql([]));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripIdFar}}/weather",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripIdFar}}", "weather"]
            }
          }
        },
