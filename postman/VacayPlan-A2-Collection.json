    {
      "name": "Admin - CoR Pattern (Rodney #89)",
      "description": "All admin routes require protect -> adminProtect chain. Use an admin account JWT in {{adminToken}} for these.\n\nTo get an admin token: log in with your admin account and manually copy the token into the {{adminToken}} environment variable.",
      "item": [
        {
          "name": "Admin Login - get adminToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) pm.environment.set('adminToken', json.token);",
                  "    pm.test('Admin login 200', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vacayplan.com\",\n  \"password\": \"AdminPass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Non-admin JWT hits admin route (403)",
          "description": "CoR step 2 — adminProtect blocks a valid but non-admin JWT.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "No JWT hits admin route (401)",
          "description": "CoR step 1 — protect middleware blocks before adminProtect is reached.",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "List All Users (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (Array.isArray(json) && json.length > 0) {",
                  "        pm.environment.set('userId', json[json.length - 1]._id);",
                  "    }",
                  "    pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Get User Detail (200)",
          "description": "Uses {{userId}} set by List All Users test script.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Create User via Admin (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    // Point {{userId}} at the throwaway we just created, so the later",
                  "    // Update/Delete act on it rather than the main test user.",
                  "    pm.environment.set('userId', pm.response.json()._id);",
                  "    pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "    pm.test('Created user id returned', () => pm.expect(pm.response.json()._id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Created User\",\n  \"email\": \"admin-created@delete.me\",\n  \"password\": \"Test1234!\",\n  \"role\": \"user\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Update User Status (200)",
          "description": "Uses {{userId}}. Patch status to deactivated.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"deactivated\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "List All Trips - admin (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/trips",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "trips"]
            }
          }
        },
        {
          "name": "Delete User via Admin (204)",
          "description": "Deletes {{userId}} — the test user created by register. Run last in this folder.",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Trips + State Pattern (Lance #90)",
      "description": "Trip CRUD and State pattern transition tests. Run Create Trip first to populate {{tripId}}.",
      "item": [
        {
          "name": "Create Trip (201)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Dates within Open-Meteo's forecast window so the weather happy-path",
                  "// returns a real forecast. Computed at run time so they never go stale.",
                  "const iso = (offset) => { const d = new Date(); d.setDate(d.getDate() + offset); return d.toISOString().slice(0, 10); };",
                  "pm.environment.set('tripStart', iso(2));",
                  "pm.environment.set('tripEnd', iso(9));",
                  "pm.environment.set('activityDate', iso(3));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json._id) pm.environment.set('tripId', json._id);",
                  "    pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "    pm.test('Trip ID saved', () => pm.expect(json._id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Test Trip\",\n  \"destination\": \"Tokyo, Japan\",\n  \"startDate\": \"{{tripStart}}\",\n  \"endDate\": \"{{tripEnd}}\",\n  \"budget\": 5000,\n  \"notes\": \"Test trip for Postman collection\",\n  \"status\": \"planning\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips",
              "host": ["{{base_url}}"],
              "path": ["api", "trips"]
            }
          }
        },
        {
          "name": "List Trips (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips",
              "host": ["{{base_url}}"],
              "path": ["api", "trips"]
            }
          }
        },
        {
          "name": "Get Trip by ID (200)",
          "request": {
