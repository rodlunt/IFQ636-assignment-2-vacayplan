    {
      "name": "Activities + Weather (Joe #91)",
      "description": "Activity CRUD and weather endpoint, reusing {{tripId}} from the Trips folder. The trip is deleted at the end of this folder (cascade via Facade), so the Trips folder no longer removes it before these requests run.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Auto-create a trip if tripId is not set (e.g. after Trips folder deletes it)",
              "if (!pm.environment.get('tripId')) {",
              "    pm.sendRequest({",
              "        url: pm.environment.get('base_url') + '/api/trips',",
              "        method: 'POST',",
              "        header: [",
              "            { key: 'Content-Type', value: 'application/json' },",
              "            { key: 'Authorization', value: 'Bearer ' + pm.environment.get('token') }",
              "        ],",
              "        body: {",
              "            mode: 'raw',",
              "            raw: JSON.stringify({",
              "                title: 'Activities Test Trip',",
              "                destination: 'Brisbane, Australia',",
              "                startDate: '2026-06-24',",
              "                endDate: '2026-06-30'",
              "            })",
              "        }",
              "    }, function(err, res) {",
              "        if (!err && res.code === 201) {",
              "            pm.environment.set('tripId', res.json()._id);",
              "            console.log('Pre-request: auto-created trip', res.json()._id);",
              "        }",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "item": [
        {
          "name": "Create Activity (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json._id) pm.environment.set('activityId', json._id);",
                  "    pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{activityDate}}\",\n  \"time\": \"10:00\",\n  \"location\": \"South Bank Parklands, Brisbane\",\n  \"description\": \"Morning visit to South Bank\",\n  \"status\": \"wishlist\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}/activities",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}", "activities"]
            }
          }
        },
        {
