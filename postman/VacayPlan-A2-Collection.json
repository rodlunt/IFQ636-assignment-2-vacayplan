            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Updated via Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/trips/{{tripId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trips", "{{tripId}}"]
            }
          }
        },
        {
          "name": "State: planning -> completed INVALID skip (400)",
          "description": "Trip is in planning. Skipping active is not a valid transition.",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
