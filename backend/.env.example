# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# The real values are shared out-of-band (password manager), not via git/email/WhatsApp.

# MongoDB Atlas connection string (includes user + password).
# Best practice: each dev uses their OWN Atlas DB user; only deploy/CI uses the shared cluster.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret. This throwaway DEV default is fine (local tokens only).
# Production uses a strong secret injected via GitHub Actions Secrets, never this file.
# To use your own:  openssl rand -base64 32
JWT_SECRET=dev-only-local-secret-not-for-production

# Port the backend listens on (defaults to 5001 if unset).
PORT=5001

# The trip weather feature uses the Open-Meteo API, which requires NO API key —
# there is nothing to add here for it to work. The weather adapter calls the
# public Open-Meteo geocoding + forecast endpoints directly.
